# Lab path configuration for predict_and_eval_clean
# Committed to git — paths are shared lab infrastructure, not secrets.
# Override any value by setting the corresponding environment variable before running.

# Adam's results and embeddings root (gait models, embeddings, etc.)
JAFAR_ROOT=/net/mraid20/ifs/wisdom/segal_lab/jafar/Adam

# Main LabData root (HPP body system CSVs, 10K data)
