# Segal lab genie analyses root (collaborator data, e.g. Shira glyco)
SEGAL_GENIE_ROOT=/net/mraid20/ifs/wisdom/segal_lab/genie/LabData

# HPP body system CSVs root (used by load_feature_df.py)
